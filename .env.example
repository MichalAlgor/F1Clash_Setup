DATABASE_URL=postgres://user:password@localhost:5432/f1clash
PORT=3000

# Optional: set to protect /admin/* routes with HTTP Basic Auth (username: admin)
# If unset, admin routes are open (fine for local dev)
ADMIN_PASSWORD=changeme

# Required for og:image absolute URLs in share previews (no trailing slash)
# Leave unset for local dev — og:image tags will be omitted
BASE_URL=https://f1clashsetup.com
